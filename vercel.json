{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    {
      "source": "/gtmplaybook",
      "destination": "/archive/buyer-view-system",
      "statusCode": 301
    },
    {
      "source": "/audit/betterupv2/era",
      "destination": "/audit/betterup/era",
      "statusCode": 301
    },
    {
      "source": "/audit/betterupv2",
      "destination": "/audit/betterup",
      "statusCode": 301
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
